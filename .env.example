# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Database password (set when creating the project) — used by npm run db:setup
SUPABASE_DB_PASSWORD=

# ---- PayHere (Checkout API + JS SDK) ----
# Sandbox dashboard: https://sandbox.payhere.lk → Integrations → Add Domain/App
NEXT_PUBLIC_PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
# "sandbox" or "production"
NEXT_PUBLIC_PAYHERE_ENV=sandbox
# Optional legacy flag (ignored when NEXT_PUBLIC_PAYHERE_ENV is set)
# NEXT_PUBLIC_PAYHERE_SANDBOX=true
# Optional: split checkout vs notify URLs for local ngrok testing
# PAYHERE_CHECKOUT_BASE_URL=https://YOUR-NGROK.ngrok-free.dev
# PAYHERE_NOTIFY_URL=https://YOUR-NGROK.ngrok-free.dev

# ---- App ----
# Must match a domain whitelisted in PayHere Integrations (use ngrok HTTPS for local testing)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
